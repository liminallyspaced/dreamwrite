# Normalize to LF in the repo; check out native on Windows.
* text=auto

*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf

# Binary — never touch
*.png  binary
*.jpg  binary
*.ico  binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.wav  binary
*.mp4  binary
